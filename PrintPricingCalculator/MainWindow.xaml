<Window x:Class="PrintPricingCalculator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="3D Print Pricing Calculator" Height="694" Width="1102" Icon="PricingAppInstaller.ico" Background="#F3F4F6"
        Loaded="Window_Loaded">
    <Grid Margin="15" TextBox.TextChanged="Input_TextChanged">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="10,0,10,15">
            <TextBlock Text="🖨️ 3D Print Pricing Calculator" FontSize="20" FontWeight="Bold"/>
            <CheckBox x:Name="chkDarkMode" Content="🌙 Dark Mode" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="14" FontWeight="Bold" Click="DarkMode_Click"/>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Height="579">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="10,0,10,0">
                    <TextBlock Text="⚙️ Advanced Inputs" FontWeight="Bold" FontSize="16" Margin="0,0,0,15"/>

                    <TextBlock Text="Material Efficiency Factor ❓" Cursor="Help">
                        <TextBlock.ToolTip>
                            <ToolTip MaxWidth="250" Background="#333" Foreground="White">
                                <TextBlock TextWrapping="Wrap" Text="Adds a buffer to your filament cost to cover purged plastic, failed prints, and supports. &#x0a;&#x0a;Example: 1.10 = 10% Extra Cost."/>
                            </ToolTip>
                        </TextBlock.ToolTip>
                    </TextBlock>
                    <TextBox x:Name="txtEfficiency" Text="1.10" Margin="0,0,0,10"/>

                    <TextBlock Text="Labor Hourly Rate ($/hr)"/>
                    <TextBox x:Name="txtLaborRate" Text="20.0" Margin="0,0,0,10"/>

                    <TextBlock Text="Printer Cost ($)"/>
                    <TextBox x:Name="txtPrinterCost" Text="1000" Margin="0,0,0,10"/>

                    <TextBlock Text="Est. Annual Maintenance ($)"/>
                    <TextBox x:Name="txtMaintenance" Text="75" Margin="0,0,0,10"/>

                    <TextBlock Text="Estimated Life (yrs)"/>
                    <TextBox x:Name="txtLife" Text="3" Margin="0,0,0,10"/>

                    <TextBlock Text="Estimated Uptime (%)"/>
                    <TextBox x:Name="txtUptime" Text="50" Margin="0,0,0,10"/>

                    <TextBlock Text="Printer Power (W)"/>
                    <TextBox x:Name="txtPower" Text="150" Margin="0,0,0,10"/>

                    <TextBlock Text="Electricity Cost ($/KWh)"/>
                    <TextBox x:Name="txtElecCost" Text="0.14" Margin="0,0,0,10"/>

                    <TextBlock Text="Printer Cost Buffer Factor ❓" Cursor="Help">
                        <TextBlock.ToolTip>
                            <ToolTip MaxWidth="250" Background="#333" Foreground="White">
                                <TextBlock TextWrapping="Wrap" Text="Adds a buffer to your hourly machine cost to cover hidden maintenance. &#x0a;&#x0a;Example: 1.30 = 30% Extra Cost."/>
                            </ToolTip>
                        </TextBlock.ToolTip>
                    </TextBlock>
                    <TextBox x:Name="txtBuffer" Text="1.3" Margin="0,0,0,10"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="10,0,10,0">
                    <TextBlock Text="🖨️ Core Inputs" FontWeight="Bold" FontSize="16" Margin="0,0,0,15"/>

                    <TextBlock Text="Filament Cost ($/kg)"/>
                    <TextBox x:Name="txtFilamentCost" Text="20.0" Margin="0,0,0,10"/>

                    <TextBlock Text="Total Filament Required (g)"/>
                    <TextBox x:Name="txtFilamentReq" Text="150" Margin="0,0,0,10"/>

                    <TextBlock Text="Total Printing Time (hr)"/>
                    <TextBox x:Name="txtPrintTime" Text="5.0" Margin="0,0,0,10"/>

                    <TextBlock Text="Total Labor Required (min)"/>
                    <TextBox x:Name="txtLaborTime" Text="15" Margin="0,0,0,10"/>

                    <TextBlock Text="Total Extra Hardware Cost ($)"/>
                    <TextBox x:Name="txtHardwareCost" Text="0.00" Margin="0,0,0,10"/>

                    <TextBlock Text="Total Packaging Materials Cost ($)"/>
                    <TextBox x:Name="txtPackagingCost" Text="1.50" Margin="0,0,0,10"/>

                    <TextBlock Text="Postage/Shipping ($)"/>
                    <TextBox x:Name="txtPostage" Text="4.00" Margin="0,0,0,20"/>

                    <!--<Button Content="🚀 Calculate Pricing" Height="40" Background="#D83B01" Foreground="White" FontWeight="Bold" FontSize="14" Click="Calculate_Click"/>-->
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="10,0,10,0">
                    <TextBlock Text="📊 Results &amp; Pricing" FontWeight="Bold" FontSize="16" Margin="0,0,0,15"/>

                    <TextBlock Text="Total Materials Cost:" Foreground="Gray"/>
                    <TextBlock x:Name="lblMaterialsCost" Text="$0.00" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>

                    <TextBlock Text="Total Labor Cost:" Foreground="Gray"/>
                    <TextBlock x:Name="lblLaborCost" Text="$0.00" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>

                    <TextBlock Text="Added Machine Cost:" Foreground="Gray"/>
                    <TextBlock x:Name="lblMachineCost" Text="$0.00" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>

                    <TextBlock Text="Total Landed Cost:" Foreground="#D83B01"/>
                    <TextBlock x:Name="lblLandedCost" Text="$0.00" FontSize="28" FontWeight="Bold" Foreground="#D83B01" Margin="0,0,0,20"/>

                    <TextBlock Text="Suggested 50% Margin Price:" Foreground="Gray"/>
                    <TextBlock x:Name="lblMargin50" Text="$0.00" FontSize="16" FontWeight="Bold" Margin="0,0,0,5"/>

                    <TextBlock Text="Suggested 60% Margin Price:" Foreground="Gray"/>
                    <TextBlock x:Name="lblMargin60" Text="$0.00" FontSize="16" FontWeight="Bold" Margin="0,0,0,5"/>

                    <TextBlock Text="Suggested 70% Margin Price:" Foreground="Gray"/>
                    <TextBlock x:Name="lblMargin70" Text="$0.00" FontSize="16" FontWeight="Bold" Margin="0,0,0,25"/>

                    <TextBlock Text="📁 Save Quote" FontWeight="Bold" FontSize="16" Margin="0,0,0,15"/>

                    <TextBlock Text="File / Part Name"/>
                    <TextBox x:Name="txtFileName" Text="My Awesome Print" Margin="0,0,0,10"/>

                    <TextBlock Text="Designer Name"/>
                    <TextBox x:Name="txtDesignerName" Text="3BC Creations" Margin="0,0,0,15"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="💾 Save" Width="90" Height="30" Margin="0,0,10,0" Background="#107C10" Foreground="White" FontWeight="Bold" Click="Save_Click"/>
                        <Button Content="📂 Load" Width="90" Height="30" Margin="0,0,10,0" Background="#0078D7" Foreground="White" FontWeight="Bold" Click="Load_Click"/>
                        <Button Content="🖨️ PDF / Print" Width="100" Height="30" Background="#606060" Foreground="White" FontWeight="Bold" Click="Print_Click"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>
