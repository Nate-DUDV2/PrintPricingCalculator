<Window x:Class="PrintPricingCalculator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="3D Print Pricing Calculator" Height="850" Width="1000" 
        Icon="PricingAppInstaller.ico" Background="{DynamicResource AppBackground}"
        Loaded="Window_Loaded">

    <Window.Resources>
        <SolidColorBrush x:Key="AppBackground" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="CardBackground" Color="#252526"/>
        <SolidColorBrush x:Key="PrimaryText" Color="White"/>
        <SolidColorBrush x:Key="SecondaryText" Color="#CCCCCC"/>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8,0,8,0"/>
            <Setter Property="Margin" Value="0,5,0,15"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#DDDDDD"/>
        </Style>

        <Style TargetType="Border" x:Key="CardStyle">
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="15" Opacity="0.2" ShadowDepth="4" Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="12"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Border Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track" IsDirectionReversed="true">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="{DynamicResource SecondaryText}" 
                                                        CornerRadius="5" 
                                                        Margin="2,0,2,0"
                                                        Opacity="0.6"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="10" TextBox.TextChanged="Input_TextChanged">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="15,10,15,20">
            <TextBlock Text="🖨️ 3D Print Pricing Calculator" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource PrimaryText}"/>
            <CheckBox x:Name="chkDarkMode" Content="🌙 Dark Mode" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource PrimaryText}" Click="DarkMode_Click"/>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <Expander x:Name="expAdvanced" Header="⚙️ Shop &amp; Machine Settings" Foreground="{DynamicResource PrimaryText}" FontWeight="Bold" FontSize="16" Margin="10,0,10,0" IsExpanded="False">
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Material Efficiency Factor ❓" Foreground="{DynamicResource SecondaryText}" Cursor="Help">
                                    <TextBlock.ToolTip>
                                        <ToolTip MaxWidth="250" Background="#333" Foreground="White">
                                            <TextBlock TextWrapping="Wrap" Text="Buffer for purged plastic, failed prints, and supports. (1.10 = +10%)"/>
                                        </ToolTip>
                                    </TextBlock.ToolTip>
                                </TextBlock>
                                <TextBox x:Name="txtEfficiency" Text="1.10"/>

                                <TextBlock Text="Labor Hourly Rate ($/hr)" Foreground="{DynamicResource SecondaryText}"/>
                                <TextBox x:Name="txtLaborRate" Text="20.0"/>

                                <TextBlock Text="Printer Cost ($)" Foreground="{DynamicResource SecondaryText}"/>
                                <TextBox x:Name="txtPrinterCost" Text="1000"/>

                                <TextBlock Text="Est. Annual Maintenance ($)" Foreground="{DynamicResource SecondaryText}"/>
                                <TextBox x:Name="txtMaintenance" Text="75"/>

                                <TextBlock Text="Estimated Life (yrs)" Foreground="{DynamicResource SecondaryText}"/>
                                <TextBox x:Name="txtLife" Text="3"/>

                                <TextBlock Text="Estimated Uptime (%)" Foreground="{DynamicResource SecondaryText}"/>
                                <TextBox x:Name="txtUptime" Text="50"/>

                                <TextBlock Text="Printer Power (W)" Foreground="{DynamicResource SecondaryText}"/>
                                <TextBox x:Name="txtPower" Text="150"/>

                                <TextBlock Text="Electricity Cost ($/KWh)" Foreground="{DynamicResource SecondaryText}"/>
                                <TextBox x:Name="txtElecCost" Text="0.14"/>

                                <TextBlock Text="Printer Cost Buffer Factor ❓" Foreground="{DynamicResource SecondaryText}" Cursor="Help">
                                    <TextBlock.ToolTip>
                                        <ToolTip MaxWidth="250" Background="#333" Foreground="White">
                                            <TextBlock TextWrapping="Wrap" Text="Buffer for hidden maintenance. (1.30 = +30%)"/>
                                        </ToolTip>
                                    </TextBlock.ToolTip>
                                </TextBlock>
                                <TextBox x:Name="txtBuffer" Text="1.3"/>
                            </StackPanel>
                        </Border>
                    </Expander>
                </StackPanel>

                <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="🖨️ Core Print Details" FontWeight="Bold" FontSize="18" Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,20"/>

                        <TextBlock Text="Filament Cost ($/kg)" Foreground="{DynamicResource SecondaryText}"/>
                        <TextBox x:Name="txtFilamentCost" Text="20.0"/>

                        <TextBlock Text="Total Filament Required (g)" Foreground="{DynamicResource SecondaryText}"/>
                        <TextBox x:Name="txtFilamentReq" Text="150"/>

                        <TextBlock Text="Total Printing Time (hr)" Foreground="{DynamicResource SecondaryText}"/>
                        <TextBox x:Name="txtPrintTime" Text="5.0"/>

                        <TextBlock Text="Total Labor Required (min)" Foreground="{DynamicResource SecondaryText}"/>
                        <TextBox x:Name="txtLaborTime" Text="15"/>

                        <TextBlock Text="Total Extra Hardware Cost ($)" Foreground="{DynamicResource SecondaryText}"/>
                        <TextBox x:Name="txtHardwareCost" Text="0.00"/>

                        <TextBlock Text="Total Packaging Cost ($)" Foreground="{DynamicResource SecondaryText}"/>
                        <TextBox x:Name="txtPackagingCost" Text="1.50"/>

                        <TextBlock Text="Postage/Shipping ($)" Foreground="{DynamicResource SecondaryText}"/>
                        <TextBox x:Name="txtPostage" Text="4.00" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Column="2">

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="📊 Final Pricing" FontWeight="Bold" FontSize="18" Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,15"/>

                            <Grid Margin="0,0,0,10">
                                <TextBlock Text="Materials:" Foreground="{DynamicResource SecondaryText}" HorizontalAlignment="Left"/>
                                <TextBlock x:Name="lblMaterialsCost" Text="$0.00" FontWeight="Bold" Foreground="{DynamicResource PrimaryText}" HorizontalAlignment="Right"/>
                            </Grid>

                            <Grid Margin="0,0,0,10">
                                <TextBlock Text="Labor:" Foreground="{DynamicResource SecondaryText}" HorizontalAlignment="Left"/>
                                <TextBlock x:Name="lblLaborCost" Text="$0.00" FontWeight="Bold" Foreground="{DynamicResource PrimaryText}" HorizontalAlignment="Right"/>
                            </Grid>

                            <Grid Margin="0,0,0,15">
                                <TextBlock Text="Machine Wear:" Foreground="{DynamicResource SecondaryText}" HorizontalAlignment="Left"/>
                                <TextBlock x:Name="lblMachineCost" Text="$0.00" FontWeight="Bold" Foreground="{DynamicResource PrimaryText}" HorizontalAlignment="Right"/>
                            </Grid>

                            <Border Background="#D83B01" CornerRadius="8" Padding="15" Margin="0,5,0,20">
                                <StackPanel>
                                    <TextBlock Text="Total Landed Cost:" Foreground="#FAD8CC" FontSize="14" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="lblLandedCost" Text="$0.00" FontSize="36" FontWeight="Bold" Foreground="White" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="Suggested Retail Pricing:" Foreground="{DynamicResource PrimaryText}" FontWeight="SemiBold" Margin="0,0,0,10"/>
                            <Grid Margin="0,0,0,5">
                                <TextBlock Text="50% Margin:" Foreground="{DynamicResource SecondaryText}" HorizontalAlignment="Left"/>
                                <TextBlock x:Name="lblMargin50" Text="$0.00" FontWeight="Bold" Foreground="{DynamicResource PrimaryText}" HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid Margin="0,0,0,5">
                                <TextBlock Text="60% Margin:" Foreground="{DynamicResource SecondaryText}" HorizontalAlignment="Left"/>
                                <TextBlock x:Name="lblMargin60" Text="$0.00" FontWeight="Bold" Foreground="{DynamicResource PrimaryText}" HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid>
                                <TextBlock Text="70% Margin:" Foreground="{DynamicResource SecondaryText}" HorizontalAlignment="Left"/>
                                <TextBlock x:Name="lblMargin70" Text="$0.00" FontWeight="Bold" Foreground="{DynamicResource PrimaryText}" HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="📁 Project File" FontWeight="Bold" FontSize="18" Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,15"/>

                            <TextBlock Text="File / Part Name" Foreground="{DynamicResource SecondaryText}"/>
                            <TextBox x:Name="txtFileName" Text="My Awesome Print"/>

                            <TextBlock Text="Designer Name" Foreground="{DynamicResource SecondaryText}"/>
                            <TextBox x:Name="txtDesignerName" Text="3BC Creations"/>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                                <Button Content="💾 Save" Width="85" Height="32" Margin="0,0,10,0" Background="#107C10" Foreground="White" FontWeight="Bold" BorderThickness="0" Click="Save_Click"/>
                                <Button Content="📂 Load" Width="85" Height="32" Margin="0,0,10,0" Background="#0078D7" Foreground="White" FontWeight="Bold" BorderThickness="0" Click="Load_Click"/>
                                <Button Content="🖨️ PDF" Width="85" Height="32" Background="#606060" Foreground="White" FontWeight="Bold" BorderThickness="0" Click="Print_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>